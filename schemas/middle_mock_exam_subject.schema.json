{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MiddleMockExamSubject",
  "type": "object",
  "required": [
    "level",
    "subject_id",
    "subject",
    "generation_order",
    "target_total",
    "source_strategy",
    "chapter_allocations",
    "questions",
    "quality_checks"
  ],
  "additionalProperties": false,
  "properties": {
    "level": {
      "type": "string",
      "const": "中級"
    },
    "subject_id": {
      "type": "string",
      "enum": ["mid-s1", "mid-s2", "mid-s3"]
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "generation_order": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "target_total": {
      "type": "integer",
      "const": 100
    },
    "source_strategy": {
      "type": "string",
      "minLength": 1
    },
    "chapter_allocations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "count"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "questions": {
      "type": "array",
      "minItems": 100,
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": [
          "id",
          "chapter_id",
          "chapter_title",
          "question",
          "options",
          "answer",
          "explanation",
          "difficulty",
          "type",
          "tags",
          "source_refs",
          "card"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "chapter_id": {"type": "string", "minLength": 1},
          "chapter_title": {"type": "string", "minLength": 1},
          "question": {"type": "string", "minLength": 1},
          "options": {
            "type": "object",
            "required": ["A", "B", "C", "D"],
            "additionalProperties": false,
            "properties": {
              "A": {"type": "string", "minLength": 1},
              "B": {"type": "string", "minLength": 1},
              "C": {"type": "string", "minLength": 1},
              "D": {"type": "string", "minLength": 1}
            }
          },
          "answer": {
            "type": "string",
            "enum": ["A", "B", "C", "D"]
          },
          "explanation": {"type": "string", "minLength": 1},
          "difficulty": {
            "type": "string",
            "enum": ["易", "中", "難"]
          },
          "type": {"type": "string", "minLength": 1},
          "tags": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "source_refs": {
            "type": "object",
            "required": ["guide_path", "chapter_id", "basis"],
            "additionalProperties": false,
            "properties": {
              "guide_path": {"type": "string", "minLength": 1},
              "chapter_id": {"type": "string", "minLength": 1},
              "basis": {"type": "string", "minLength": 1}
            }
          },
          "card": {
            "type": "object",
            "required": ["concept", "mnemonic", "confusion", "frequency"],
            "additionalProperties": false,
            "properties": {
              "concept": {"type": "string", "minLength": 1},
              "mnemonic": {"type": "string", "minLength": 1},
              "confusion": {"type": "string", "minLength": 1},
              "frequency": {
                "type": "string",
                "enum": ["高", "中", "低"]
              }
            }
          }
        }
      }
    },
    "quality_checks": {
      "type": "object",
      "required": [
        "question_count",
        "chapter_distribution_verified",
        "dedupe_checked_against_official_and_existing",
        "single_answer_verified"
      ],
      "additionalProperties": false,
      "properties": {
        "question_count": {"type": "integer", "const": 100},
        "chapter_distribution_verified": {"type": "boolean"},
        "dedupe_checked_against_official_and_existing": {"type": "boolean"},
        "single_answer_verified": {"type": "boolean"}
      }
    }
  }
}
