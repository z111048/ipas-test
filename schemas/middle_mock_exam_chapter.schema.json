{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MiddleMockExamChapter",
  "type": "object",
  "required": ["level", "subject_id", "chapter_id", "chapter_title", "target_count", "questions"],
  "additionalProperties": false,
  "properties": {
    "level": {"type": "string", "const": "中級"},
    "subject_id": {"type": "string", "enum": ["mid-s1", "mid-s2", "mid-s3"]},
    "chapter_id": {"type": "string", "minLength": 1},
    "chapter_title": {"type": "string", "minLength": 1},
    "target_count": {"type": "integer", "minimum": 1, "maximum": 20},
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": [
          "id",
          "chapter_id",
          "chapter_title",
          "question",
          "options",
          "answer",
          "explanation",
          "difficulty",
          "type",
          "tags",
          "source_refs",
          "card"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "chapter_id": {"type": "string", "minLength": 1},
          "chapter_title": {"type": "string", "minLength": 1},
          "question": {"type": "string", "minLength": 1},
          "options": {
            "type": "object",
            "required": ["A", "B", "C", "D"],
            "additionalProperties": false,
            "properties": {
              "A": {"type": "string", "minLength": 1},
              "B": {"type": "string", "minLength": 1},
              "C": {"type": "string", "minLength": 1},
              "D": {"type": "string", "minLength": 1}
            }
          },
          "answer": {"type": "string", "enum": ["A", "B", "C", "D"]},
          "explanation": {"type": "string", "minLength": 1},
          "difficulty": {"type": "string", "enum": ["易", "中", "難"]},
          "type": {"type": "string", "minLength": 1},
          "tags": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "source_refs": {
            "type": "object",
            "required": ["guide_path", "chapter_id", "basis"],
            "additionalProperties": false,
            "properties": {
              "guide_path": {"type": "string", "minLength": 1},
              "chapter_id": {"type": "string", "minLength": 1},
              "basis": {"type": "string", "minLength": 1}
            }
          },
          "card": {
            "type": "object",
            "required": ["concept", "mnemonic", "confusion", "frequency"],
            "additionalProperties": false,
            "properties": {
              "concept": {"type": "string", "minLength": 1},
              "mnemonic": {"type": "string", "minLength": 1},
              "confusion": {"type": "string", "minLength": 1},
              "frequency": {"type": "string", "enum": ["高", "中", "低"]}
            }
          }
        }
      }
    }
  }
}
