        614.2
      ],
      "id": "block-58",
      "nodeId": "mid-s2c7",
      "kind": "list_item",
      "source": "page_extract"
    },
    {
      "type": "list_item",
      "depth": 7,
      "marker": "○",
      "text": "使用邏輯迴歸預測借款人違約風險，根據信用分數、收入等變數建模。",
      "pageIndex": 94,
      "bbox": [
        136.12,
        625.74,
        517.95,
        664.15
      ],
      "id": "block-59",
      "nodeId": "mid-s2c7",
      "kind": "list_item",
      "source": "page_extract"
    },
    {
      "type": "list_item",
      "depth": 5,
      "marker": "•",
      "text": "健康醫療資料分析",
      "pageIndex": 94,
      "bbox": [
        102.16,
        675.78,
